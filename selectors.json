{
  "PROMPT_INPUT": [
    "textarea",
    "div[contenteditable='true']",
    "[data-testid='chat-input']"
  ],
  "GENERATE_BUTTON": [
    "button[type='submit']",
    "button[aria-label*='Send']",
    "button[aria-label*='Generate']",
    "button[aria-label*='Submit']"
